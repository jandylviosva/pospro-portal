{
  "rewrites": [
    { "source": "/api/(.*)",     "destination": "/api/$1" },
    { "source": "/payment",      "destination": "/payment.html" },
    { "source": "/bill-payment", "destination": "/bill-payment.html" },
    { "source": "/bookings/:slug/pay", "destination": "/bookings-pay.html" },
    { "source": "/bookings/:slug", "destination": "/bookings.html" },
    { "source": "/(.*)",         "destination": "/index.html" }
  ]
}
